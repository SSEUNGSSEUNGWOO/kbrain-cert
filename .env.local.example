# kbrain-cert 환경변수 템플릿
# 실제 값은 .env.local에 (git ignore됨)

# ─────────── Supabase ───────────
# supabase.com → 프로젝트 생성 후 Settings → API에서 복사
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────── Agora (M4에서 사용) ───────────
# agora.io Console → Project → App ID + Certificate
# App ID는 클라이언트 노출 OK, Certificate는 서버 전용 (절대 노출 X)
NEXT_PUBLIC_AGORA_APP_ID=159975072afc407d90c9b07031f5acb9
AGORA_APP_CERTIFICATE=

# ─────────── Cloudflare R2 (M4 녹화) ───────────
# Cloudflare 대시보드 → R2 → S3 API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kbrain-cert-recordings
R2_PUBLIC_BASE_URL=

# ─────────── Resend (M3 이메일) ───────────
# resend.com → API Keys
# 미등록 상태에서는 lib/email/send-invitation.ts가 콘솔에 출력만 함
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# ─────────── 앱 설정 ───────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 응시자 세션 쿠키 서명용 · 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
EXAM_SESSION_SECRET=change-me-random-32-bytes
